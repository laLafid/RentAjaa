<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
 
    <application
        android:name=".RentAjaApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RentHub">
        <!-- Splash / entry point -->
        <activity
            android:name=".activities.auth.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.RentHub.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Auth -->
        <activity android:name=".activities.auth.LoginActivity"    android:exported="false" />
        <activity android:name=".activities.auth.RegisterActivity" android:exported="false" />

        <!-- Renter -->
        <activity android:name=".activities.renter.RenterMainActivity" android:exported="false" />
        <activity
            android:name=".activities.renter.VehicleDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.RentHub.VehicleDetail" />
        <activity android:name=".activities.renter.BookingActivity"       android:exported="false" />
        <activity android:name=".activities.renter.ContractActivity"      android:exported="false" />
        <activity android:name=".activities.renter.EditProfileActivity"    android:exported="false" />

        <!-- Owner -->
        <activity android:name=".activities.owner.OwnerMainActivity"   android:exported="false" />
        <activity android:name=".activities.owner.AddVehicleActivity"  android:exported="false" />
        <activity android:name=".activities.owner.BookingDetailActivity" android:exported="false" />

    </application>

</manifest>